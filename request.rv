// The request a caller builds and the reply it gets back, both neutral
// across providers. A ChatRequest is a builder: unset numeric options carry a
// sentinel (a negative temperature or top_p, a zero max_tokens) so an adapter
// includes only the fields the caller actually set.

import std/sync { Mutex, mutex }
import "./message" { Message, Role, ToolCall, ToolDef }

// A cross-goroutine stop flag for a streaming completion. Attach one to a
// request with .cancelable(token); calling cancel() from any goroutine stops
// the stream at the next chunk (or text delta) boundary, and the reply comes
// back Ok with finish_reason "canceled" and whatever text had streamed. A
// stream blocked waiting on the network notices the cancel when the next
// chunk arrives or the read times out.
struct CancelToken {
    lock: Mutex,
    stopped: Bool,
}

impl CancelToken {
    fun new() -> CancelToken {
        return CancelToken { lock: mutex(), stopped: false }
    }

    fun cancel(self) {
        self.lock.lock()
        self.stopped = true
        self.lock.unlock()
    }

    fun canceled(self) -> Bool {
        self.lock.lock()
        let v = self.stopped
        self.lock.unlock()
        return v
    }
}

// Token counts from the provider. A provider that omits a count leaves it 0.
struct Usage {
    prompt_tokens: Int,
    completion_tokens: Int,
    total_tokens: Int,
    // How much of the input was served from, or written to, the prompt cache.
    // prompt_tokens already counts these; they are broken out so a caller can
    // price cache reads (cheaper) and cache writes (slightly dearer) on their
    // own. 0 when the provider reports no caching.
    cache_read_tokens: Int,
    cache_write_tokens: Int,
}

// A model's reply. `content` is the text; `tool_calls` is non-empty when the
// model asked to call tools instead of (or alongside) answering. `raw` is the
// provider's untouched JSON response, for anything the neutral shape omits.
struct ChatReply {
    content: String,
    model: String,
    finish_reason: String,
    tool_calls: List<ToolCall>,
    usage: Usage,
    raw: String,
}

struct ChatRequest {
    // "provider/model", for example "openai/gpt-4o" or "anthropic/claude-3-5-sonnet-latest".
    model: String,
    messages: List<Message>,
    temperature: Float,
    max_tokens: Int,
    top_p: Float,
    tools: List<ToolDef>,
    // Overrides. An empty api_key falls back to the provider's env var; an
    // empty base_url falls back to the provider's default endpoint.
    api_key: String,
    base_url: String,
    // Extra request header lines ("Key: Value"), joined onto the defaults.
    extra_headers: String,
    // Request deadline in milliseconds; 0 means aviary's default (120s for
    // a buffered completion, 30s per read on a stream).
    timeout_ms: Int,
    // Retries on transient failures (429, 5xx, transport errors), with
    // exponential backoff between attempts.
    retries: Int,
    // Ask the provider to cache the static prefix (the system prompt and the
    // tool list) so repeated calls within and across a conversation re-use it
    // instead of re-billing the whole prefix each time. Only the Anthropic
    // adapter acts on this today; it is a no-op for providers without explicit
    // cache control.
    cache: Bool,
    // The stream's stop flag; a fresh (never canceled) token by default.
    cancel: CancelToken,
}

impl ChatRequest {
    fun new(model: String) -> ChatRequest {
        let msgs: List<Message> = []
        let tools: List<ToolDef> = []
        return ChatRequest {
            model,
            messages: msgs,
            temperature: 0.0 - 1.0,
            max_tokens: 0,
            top_p: 0.0 - 1.0,
            tools,
            api_key: "",
            base_url: "",
            extra_headers: "",
            timeout_ms: 0,
            retries: 2,
            cache: false,
            cancel: CancelToken.new(),
        }
    }

    // Attach a cancel token, so another goroutine can stop this request's
    // stream mid-reply. See CancelToken.
    fun cancelable(self, token: CancelToken) -> ChatRequest {
        self.cancel = token
        return self
    }

    fun message(self, m: Message) -> ChatRequest {
        self.messages.push(m)
        return self
    }

    fun system(self, text: String) -> ChatRequest {
        self.messages.push(Message.system(text))
        return self
    }

    fun user(self, text: String) -> ChatRequest {
        self.messages.push(Message.user(text))
        return self
    }

    fun assistant(self, text: String) -> ChatRequest {
        self.messages.push(Message.assistant(text))
        return self
    }

    fun temperature(self, t: Float) -> ChatRequest {
        self.temperature = t
        return self
    }

    fun max_tokens(self, n: Int) -> ChatRequest {
        self.max_tokens = n
        return self
    }

    fun top_p(self, p: Float) -> ChatRequest {
        self.top_p = p
        return self
    }

    fun tool(self, t: ToolDef) -> ChatRequest {
        self.tools.push(t)
        return self
    }

    fun key(self, k: String) -> ChatRequest {
        self.api_key = k
        return self
    }

    fun base(self, url: String) -> ChatRequest {
        self.base_url = url
        return self
    }

    fun header(self, line: String) -> ChatRequest {
        if self.extra_headers == "" {
            self.extra_headers = line
        } else {
            self.extra_headers = "${self.extra_headers}\n${line}"
        }
        return self
    }

    // Deadline for the request in milliseconds. On a buffered completion it
    // bounds the whole call; on a stream it bounds the connect and each
    // read. 0 restores aviary's defaults.
    fun timeout(self, ms: Int) -> ChatRequest {
        self.timeout_ms = ms
        return self
    }

    // How many times a transient failure (429, 5xx, transport error) is
    // retried, with exponential backoff. 0 disables retries.
    fun retries(self, n: Int) -> ChatRequest {
        self.retries = n
        return self
    }

    // Mark the static prefix (system prompt and tools) as cacheable. See the
    // cache field. Only the Anthropic adapter uses this today.
    fun cache(self, on: Bool) -> ChatRequest {
        self.cache = on
        return self
    }
}
