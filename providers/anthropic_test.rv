import std/test { assert_eq_str, assert_eq_int, assert_true, assert_false }
import std/json { JsonValue, parse }
import "../jsonutil" { Obj, field, index, as_str, as_int_or, as_list }
import "../message" { Message, Role, ToolCall, ToolDef }
import "../request" { ChatRequest, ChatReply }
import "./anthropic" { build_body, parse_reply }

fun must_parse(s: String) -> JsonValue {
    return match parse(s) {
        Ok(v) -> v,
        Err(e) -> {
            assert_true(false)
            JsonValue.Null
        },
    }
}

fun test_system_is_hoisted_out_of_messages() {
    let req = ChatRequest.new("anthropic/claude").system("be terse").user("hi")
    let j = must_parse(build_body("claude-3-5-sonnet-latest", req))
    assert_eq_str(as_str(field(j, "system")), "be terse")
    let msgs = as_list(field(j, "messages"))
    assert_eq_int(msgs.len(), 1)
    assert_eq_str(as_str(field(msgs[0], "role")), "user")
}

fun test_max_tokens_defaults_when_unset() {
    let req = ChatRequest.new("anthropic/claude").user("hi")
    let j = must_parse(build_body("claude", req))
    assert_eq_int(as_int_or(field(j, "max_tokens"), 0), 1024)
}

fun test_max_tokens_honors_the_request() {
    let req = ChatRequest.new("anthropic/claude").user("hi").max_tokens(500)
    let j = must_parse(build_body("claude", req))
    assert_eq_int(as_int_or(field(j, "max_tokens"), 0), 500)
}

fun test_tool_use_is_a_content_block() {
    let call = ToolCall { id: "tu_1", name: "get_weather", arguments: "{\"city\":\"NYC\"}" }
    let req = ChatRequest.new("anthropic/claude").user("weather?").message(
        Message.assistant_calls("let me check", [call]),
    )
    let j = must_parse(build_body("claude", req))
    let msgs = as_list(field(j, "messages"))
    let blocks = as_list(field(msgs[1], "content"))
    // A text block then a tool_use block.
    assert_eq_int(blocks.len(), 2)
    assert_eq_str(as_str(field(blocks[0], "type")), "text")
    assert_eq_str(as_str(field(blocks[1], "type")), "tool_use")
    assert_eq_str(as_str(field(blocks[1], "name")), "get_weather")
    // arguments were parsed into an object, so city is readable.
    assert_eq_str(as_str(field(field(blocks[1], "input"), "city")), "NYC")
}

fun test_tool_result_becomes_a_user_block() {
    let req = ChatRequest.new("anthropic/claude").message(
        Message.tool_result("tu_1", "get_weather", "72F"),
    )
    let j = must_parse(build_body("claude", req))
    let msgs = as_list(field(j, "messages"))
    assert_eq_str(as_str(field(msgs[0], "role")), "user")
    let blocks = as_list(field(msgs[0], "content"))
    assert_eq_str(as_str(field(blocks[0], "type")), "tool_result")
    assert_eq_str(as_str(field(blocks[0], "tool_use_id")), "tu_1")
}

fun test_tools_use_input_schema() {
    let req = ChatRequest.new("anthropic/claude").user("weather?").tool(
        ToolDef.new("get_weather", "weather", Obj.new().str("type", "object").build()),
    )
    let j = must_parse(build_body("claude", req))
    let tools = as_list(field(j, "tools"))
    assert_eq_int(tools.len(), 1)
    assert_eq_str(as_str(field(tools[0], "name")), "get_weather")
    assert_false(field(tools[0], "input_schema").is_null())
}

fun test_cache_marks_the_system_and_the_last_tool() {
    let req = ChatRequest.new("anthropic/claude").system("be terse").user("hi").tool(
        ToolDef.new("a", "first", Obj.new().str("type", "object").build()),
    ).tool(ToolDef.new("b", "second", Obj.new().str("type", "object").build())).cache(true)
    let j = must_parse(build_body("claude", req))
    // System becomes an array with one text block carrying an ephemeral marker.
    let sys = as_list(field(j, "system"))
    assert_eq_int(sys.len(), 1)
    assert_eq_str(as_str(field(sys[0], "type")), "text")
    assert_eq_str(as_str(field(sys[0], "text")), "be terse")
    assert_eq_str(as_str(field(field(sys[0], "cache_control"), "type")), "ephemeral")
    // Only the last tool carries the marker, so the whole tool list is one
    // cache segment.
    let tools = as_list(field(j, "tools"))
    assert_eq_int(tools.len(), 2)
    assert_true(field(tools[0], "cache_control").is_null())
    assert_eq_str(as_str(field(field(tools[1], "cache_control"), "type")), "ephemeral")
}

fun test_no_cache_keeps_the_system_a_plain_string() {
    let req = ChatRequest.new("anthropic/claude").system("be terse").user("hi").tool(
        ToolDef.new("a", "first", Obj.new().str("type", "object").build()),
    )
    let j = must_parse(build_body("claude", req))
    // Default: unchanged shape, a plain string system and an unmarked tool.
    assert_eq_str(as_str(field(j, "system")), "be terse")
    let tools = as_list(field(j, "tools"))
    assert_true(field(tools[0], "cache_control").is_null())
}

fun test_parse_reply_counts_cached_input_tokens() {
    let body = "{\"model\":\"claude\",\"content\":[{\"type\":\"text\",\"text\":\"hi\"}],\"stop_reason\":\"end_turn\",\"usage\":{\"input_tokens\":10,\"cache_read_input_tokens\":100,\"cache_creation_input_tokens\":5,\"output_tokens\":4}}"
    match parse_reply(body) {
        Ok(r) -> {
            // prompt_tokens is the true total input: 10 + 100 + 5.
            assert_eq_int(r.usage.prompt_tokens, 115)
            assert_eq_int(r.usage.cache_read_tokens, 100)
            assert_eq_int(r.usage.cache_write_tokens, 5)
            assert_eq_int(r.usage.completion_tokens, 4)
        },
        Err(e) -> assert_true(false),
    }
}

fun test_parse_text_reply() {
    let body = "{\"model\":\"claude-3-5-sonnet\",\"content\":[{\"type\":\"text\",\"text\":\"Hi there\"}],\"stop_reason\":\"end_turn\",\"usage\":{\"input_tokens\":10,\"output_tokens\":4}}"
    match parse_reply(body) {
        Ok(r) -> {
            assert_eq_str(r.content, "Hi there")
            assert_eq_str(r.finish_reason, "end_turn")
            assert_eq_int(r.usage.prompt_tokens, 10)
            assert_eq_int(r.usage.completion_tokens, 4)
            assert_eq_int(r.usage.total_tokens, 14)
        },
        Err(e) -> assert_true(false),
    }
}

fun test_parse_tool_use_reply() {
    let body = "{\"model\":\"claude\",\"content\":[{\"type\":\"text\",\"text\":\"checking\"},{\"type\":\"tool_use\",\"id\":\"tu_9\",\"name\":\"get_weather\",\"input\":{\"city\":\"NYC\"}}],\"stop_reason\":\"tool_use\"}"
    match parse_reply(body) {
        Ok(r) -> {
            assert_eq_str(r.content, "checking")
            assert_eq_str(r.finish_reason, "tool_use")
            assert_eq_int(r.tool_calls.len(), 1)
            assert_eq_str(r.tool_calls[0].id, "tu_9")
            assert_eq_str(r.tool_calls[0].name, "get_weather")
            assert_true(r.tool_calls[0].arguments.contains("NYC"))
        },
        Err(e) -> assert_true(false),
    }
}
