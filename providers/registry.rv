// The provider registry: which adapter, endpoint, and credential each
// provider name maps to. Most providers speak the OpenAI chat-completions
// shape, so they share the OpenAI kind and differ only by base URL and key;
// Anthropic, Gemini, and Cohere have their own kinds and adapters.

import std/env { get_env, has_env }
import std/error { Error, error }

// Which adapter handles a provider.
enum ProviderKind {
    OpenAI,
    Anthropic,
    Gemini,
    Cohere,
}

// How an OpenAI-kind provider carries its key. Bearer is the norm; Azure
// uses an api-key header.
enum Auth {
    Bearer,
    ApiKeyHeader,
}

// A provider's static entry, before the key and any override are resolved.
struct Base {
    kind: ProviderKind,
    // Default endpoint root. The adapter appends its path (for example
    // "/chat/completions").
    default_base: String,
    // Environment variable that overrides the base URL, or "" for none.
    // Used by self-hosted or resource-scoped providers (Ollama, Azure).
    base_env: String,
    // Environment variable holding the API key.
    key_env: String,
    auth: Auth,
    // False for a keyless provider such as a local Ollama server.
    needs_key: Bool,
}

// A resolved provider: everything an adapter needs to make the call.
struct Spec {
    kind: ProviderKind,
    base_url: String,
    key: String,
    key_env: String,
    auth: Auth,
}

// The static entry for a provider name, or an error listing the known names.
fun base_spec(provider: String) -> Result<Base, Error> {
    // OpenAI and the OpenAI-compatible fleet.
    if provider == "openai" {
        return Ok(_openai("https://api.openai.com/v1", "OPENAI_API_KEY"))
    }
    if provider == "groq" {
        return Ok(_openai("https://api.groq.com/openai/v1", "GROQ_API_KEY"))
    }
    if provider == "mistral" {
        return Ok(_openai("https://api.mistral.ai/v1", "MISTRAL_API_KEY"))
    }
    if provider == "deepseek" {
        return Ok(_openai("https://api.deepseek.com/v1", "DEEPSEEK_API_KEY"))
    }
    if provider == "xai" || provider == "grok" {
        return Ok(_openai("https://api.x.ai/v1", "XAI_API_KEY"))
    }
    if provider == "together" {
        return Ok(_openai("https://api.together.xyz/v1", "TOGETHER_API_KEY"))
    }
    if provider == "fireworks" {
        return Ok(_openai("https://api.fireworks.ai/inference/v1", "FIREWORKS_API_KEY"))
    }
    if provider == "perplexity" {
        return Ok(_openai("https://api.perplexity.ai", "PERPLEXITY_API_KEY"))
    }
    if provider == "openrouter" {
        return Ok(_openai("https://openrouter.ai/api/v1", "OPENROUTER_API_KEY"))
    }
    if provider == "deepinfra" {
        return Ok(_openai("https://api.deepinfra.com/v1/openai", "DEEPINFRA_API_KEY"))
    }
    if provider == "nebius" {
        return Ok(_openai("https://api.studio.nebius.ai/v1", "NEBIUS_API_KEY"))
    }
    if provider == "moonshot" {
        return Ok(_openai("https://api.moonshot.cn/v1", "MOONSHOT_API_KEY"))
    }
    if provider == "ollama" {
        // Local, keyless. OLLAMA_HOST may point elsewhere; the adapter appends
        // the OpenAI-compatible path.
        return Ok(
            Base {
                kind: ProviderKind.OpenAI,
                default_base: "http://localhost:11434/v1",
                base_env: "OLLAMA_HOST",
                key_env: "",
                auth: Auth.Bearer,
                needs_key: false,
            },
        )
    }
    if provider == "azure" {
        // Resource-scoped: AZURE_API_BASE gives the endpoint root, the model
        // is the deployment name, and the key rides an api-key header.
        return Ok(
            Base {
                kind: ProviderKind.OpenAI,
                default_base: "",
                base_env: "AZURE_API_BASE",
                key_env: "AZURE_API_KEY",
                auth: Auth.ApiKeyHeader,
                needs_key: true,
            },
        )
    }
    if provider == "custom" {
        // A generic OpenAI-compatible endpoint. Set the base with .base(...)
        // on the request or AVIARY_BASE_URL, and the key with .key(...) or
        // AVIARY_API_KEY.
        return Ok(
            Base {
                kind: ProviderKind.OpenAI,
                default_base: "",
                base_env: "AVIARY_BASE_URL",
                key_env: "AVIARY_API_KEY",
                auth: Auth.Bearer,
                needs_key: false,
            },
        )
    }

    // Native adapters.
    if provider == "anthropic" || provider == "claude" {
        return Ok(
            Base {
                kind: ProviderKind.Anthropic,
                default_base: "https://api.anthropic.com/v1",
                base_env: "",
                key_env: "ANTHROPIC_API_KEY",
                auth: Auth.ApiKeyHeader,
                needs_key: true,
            },
        )
    }
    if provider == "gemini" || provider == "google" {
        return Ok(
            Base {
                kind: ProviderKind.Gemini,
                default_base: "https://generativelanguage.googleapis.com/v1beta",
                base_env: "",
                key_env: "GEMINI_API_KEY",
                auth: Auth.ApiKeyHeader,
                needs_key: true,
            },
        )
    }
    if provider == "cohere" {
        return Ok(
            Base {
                kind: ProviderKind.Cohere,
                default_base: "https://api.cohere.com/v2",
                base_env: "",
                key_env: "COHERE_API_KEY",
                auth: Auth.Bearer,
                needs_key: true,
            },
        )
    }

    return Err(
        error(
            "unknown provider '${provider}'; see the README for the supported list, or use 'custom' with a base URL",
        ),
    )
}

fun _openai(base: String, key_env: String) -> Base {
    return Base {
        kind: ProviderKind.OpenAI,
        default_base: base,
        base_env: "",
        key_env,
        auth: Auth.Bearer,
        needs_key: true,
    }
}

// Resolve a provider into a Spec, applying the request's key and base
// overrides and then the environment. Errors when a required key is missing
// or an override-only base is unset.
fun resolve(provider: String, override_key: String, override_base: String) -> Result<Spec, Error> {
    let b = base_spec(provider)?

    let base = override_base
    if base == "" && b.base_env != "" && has_env(b.base_env) {
        base = get_env(b.base_env)
    }
    if base == "" {
        base = b.default_base
    }
    if base == "" {
        return Err(
            error(
                "provider '${provider}' needs a base URL; set it with .base(...) or the ${b.base_env} environment variable",
            ),
        )
    }

    let key = override_key
    if key == "" && b.key_env != "" {
        key = get_env(b.key_env)
    }
    if b.needs_key && key == "" {
        return Err(
            error(
                "provider '${provider}' needs an API key; set it with .key(...) or the ${b.key_env} environment variable",
            ),
        )
    }

    return Ok(Spec { kind: b.kind, base_url: base, key, key_env: b.key_env, auth: b.auth })
}

// Strip a trailing slash so a path can be appended cleanly.
fun trim_base(base: String) -> String {
    if base.ends_with("/") {
        return base.substring(0, base.length() - 1)
    }
    return base
}
