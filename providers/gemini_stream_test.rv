import std/string
import std/test { assert_eq_int, assert_eq_str, assert_true }
import "./gemini" { apply_stream_event }
import "./accum" { StreamAcc }

fun test_chunk_texts_accumulate() {
    let acc = StreamAcc.new()
    let first = apply_stream_event(
        acc,
        "{\"candidates\":[{\"content\":{\"parts\":[{\"text\":\"Sure, \"}]}}]}",
    )
    let second = apply_stream_event(
        acc,
        "{\"candidates\":[{\"content\":{\"parts\":[{\"text\":\"here.\"}]}}],\"modelVersion\":\"gemini-1.5\"}",
    )
    assert_eq_str(first, "Sure, ")
    assert_eq_str(second, "here.")
    assert_eq_str(acc.text, "Sure, here.")
    assert_eq_str(acc.model, "gemini-1.5")
}

fun test_finish_and_usage_from_last_chunk() {
    let acc = StreamAcc.new()
    apply_stream_event(
        acc,
        "{\"candidates\":[{\"content\":{\"parts\":[{\"text\":\"done\"}]},\"finishReason\":\"STOP\"}],\"usageMetadata\":{\"promptTokenCount\":8,\"candidatesTokenCount\":3,\"totalTokenCount\":11}}",
    )
    assert_eq_str(acc.finish_reason, "STOP")
    let reply = acc.to_reply()
    assert_eq_int(reply.usage.prompt_tokens, 8)
    assert_eq_int(reply.usage.total_tokens, 11)
}

fun test_function_call_part_is_captured() {
    let acc = StreamAcc.new()
    apply_stream_event(
        acc,
        "{\"candidates\":[{\"content\":{\"parts\":[{\"functionCall\":{\"name\":\"get_weather\",\"args\":{\"city\":\"NYC\"}}}]}}]}",
    )
    assert_eq_int(acc.tool_calls.len(), 1)
    assert_eq_str(acc.tool_calls[0].name, "get_weather")
    assert_true(acc.tool_calls[0].arguments.contains("NYC"))
}
